# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GoHighLevel ────────────────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# ── Twilio ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...
TWILIO_FAILOVER_NUMBER=+1...

# ── VAPI ───────────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=healthcare_staffing
POSTGRES_USER=staffing_user
POSTGRES_PASSWORD=

# ── Auth0 ──────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://api.healthcare-staffing-ai-os.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Vector DB (Pinecone) ───────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=healthcare-staffing-kb

# ── Langfuse / Monitoring ──────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com
APP_ENV=development
