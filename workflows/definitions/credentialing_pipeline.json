{
  "workflow_id": "WF-CREDENTIALING-001",
  "name": "Medical Credentialing Pipeline",
  "version": "1.0.0",
  "trigger": "pipeline_stage:intake_complete",
  "agent": "CRED-001",
  "steps": [
    {
      "step": 1,
      "name": "set_credentialing_stage",
      "action": "stage_change",
      "agent": "CRM-001",
      "to_stage": "credentialing"
    },
    {
      "step": 2,
      "name": "request_mandatory_documents",
      "action": "request_documents",
      "categories": ["identity", "licensure", "background_drug"],
      "channels": ["sms", "email"],
      "upload_link_expiry_hours": 72
    },
    {
      "step": 3,
      "name": "request_full_checklist",
      "action": "request_documents",
      "categories": [
        "education_training", "work_history",
        "malpractice", "health_immunizations"
      ],
      "channels": ["email"]
    },
    {
      "step": 4,
      "name": "monitor_expiry",
      "action": "schedule_reminders",
      "agent": "COMP-001",
      "reminder_days": [30, 14, 7]
    },
    {
      "step": 5,
      "name": "classify_received_documents",
      "action": "classify_documents",
      "confidence_threshold": 0.75,
      "low_confidence_action": "escalate_to_human"
    },
    {
      "step": 6,
      "name": "route_to_specialist",
      "action": "escalate",
      "trigger": "checklist_completion_pct:100",
      "route_to": "HUMAN",
      "tag": "human_escalation_required",
      "task_title": "SPECIALIST REVIEW: Complete credentialing file",
      "task_due_days": 2
    }
  ],
  "escalation": {
    "triggers": [
      "credential_approval",
      "authenticity_concern",
      "privileging",
      "license_interpretation",
      "final_file_approval"
    ],
    "route_to": "HUMAN",
    "severity": "high"
  }
}
